{
  "name": "@ai-apps/llm-router",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "files": ["dist"],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "bunchee",
    "dev": "bunchee --watch",
