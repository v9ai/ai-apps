  "dependencies": {
    "@ai-apps/deepseek": "workspace:*",
    "@ai-apps/qwen": "workspace:*"
  },
  "devDependencies": {
    "@jest/globals": "^30.2.0",
    "@ai-apps/jest-presets": "workspace:*",
    "@ai-apps/typescript-config": "workspace:*",
    "@types/node": "^22.15.3",
    "bunchee": "^6.4.0",
    "jest": "^30.2.0",
    "typescript": "5.9.3"
  }
}
