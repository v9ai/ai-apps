{
  "name": "agentic-healthcare",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3003",
    "build": "next build",
    "start": "next start",
    "db:push": "drizzle-kit push",
    "db:migrate": "tsx lib/db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "db:generate": "drizzle-kit generate",
    "test": "vitest run",
    "test:watch": "vitest",
    "eval": "promptfoo eval && promptfoo eval -c promptfoo.trajectory.yaml",
    "eval:qa": "promptfoo eval",
    "eval:trajectory": "promptfoo eval -c promptfoo.trajectory.yaml",
    "eval:deepeval": "python evals/trajectory_eval.py",
    "eval:rag": "python evals/ragas_eval.py",
    "eval:rag:triad": "uv run --project langgraph pytest evals/rag_triad_eval.py -v",
    "eval:rag:synth": "uv run --project langgraph pytest evals/synthesize_eval.py -v",
    "eval:rag:all": "uv run --project langgraph pytest evals/rag_triad_eval.py evals/synthesize_eval.py -v",
    "eval:conv": "uv run --project langgraph pytest evals/conversational_eval.py -v",
    "eval:trajectory:pytest": "uv run --project langgraph pytest evals/trajectory_eval.py -v",
    "eval:all": "uv run --project langgraph pytest evals/ -v",
    "eval:view": "promptfoo view"
  },
  "dependencies": {
    "@ai-apps/auth": "workspace:*",
    "@ai-apps/ui": "workspace:*",
    "@aws-sdk/client-s3": "^3.1004.0",
    "@neondatabase/serverless": "^1.0.2",
    "@radix-ui/react-checkbox": "^1.3.1",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.14",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-label": "^2.1.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.2",
    "@radix-ui/themes": "^3.3.0",
    "better-auth": "^1.5.5",
    "drizzle-orm": "^0.45.1",
    "lucide-react": "^0.511.0",
    "next": "latest",
    "next-themes": "^0.4.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "unstructured-client": "^0.31.0"
  },
  "packageManager": "pnpm@10.31.0",
  "devDependencies": {
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.4",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.10",
    "postcss": "^8",
    "promptfoo": "^0.120.26",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
