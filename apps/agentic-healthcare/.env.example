# Neon PostgreSQL
DATABASE_URL=postgresql://...

# Better Auth
BETTER_AUTH_SECRET=your-secret-at-least-32-chars
BETTER_AUTH_URL=http://localhost:3003
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3003

# Cloudflare R2
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET_NAME=healthcare-blood-tests

# LLM — mlx_lm.server (Apple Silicon, OpenAI-compatible)
# Start: ./langgraph/serve.sh
# Or:    mlx_lm.server --model mlx-community/Qwen2.5-7B-Instruct-4bit --port 8080
LLM_BASE_URL=http://localhost:8080
LLM_MODEL=mlx-community/Qwen2.5-7B-Instruct-4bit
LLM_API_KEY=unused

# Unstructured.io
UNSTRUCTURED_API_KEY=your-key
