{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "agentic-healthcare-langgraph",
  "main": "src/index.js",
  "compatibility_date": "2026-04-01",
  "observability": { "enabled": true },
  "vars": {
    // LLM defaults: a local mlx_lm.server is unreachable from Cloudflare's
    // edge, so production falls back to an OpenAI-compatible endpoint. Override
    // via `wrangler secret put LLM_BASE_URL` (or the Durable Object env below)
    // before deploying. Values shown are safe placeholders.
    "LLM_BASE_URL": "https://api.deepseek.com",
    "LLM_MODEL": "deepseek-chat"
  },
  "containers": [
    {
      "class_name": "AgenticHealthcareContainer",
      "image": "./Dockerfile",
      // standard-1 (4 GiB RAM / 0.5 vCPU) fits FastEmbed bge-large-en-v1.5
      // (~1.3 GB ONNX model) + LlamaIndex + psycopg. Bump to standard-2 if
      // ingestion pipeline OOMs on large PDFs.
      "max_instances": 1,
      "instance_type": "standard-1"
    }
  ],
  "durable_objects": {
    "bindings": [
      { "name": "CONTAINER", "class_name": "AgenticHealthcareContainer" }
    ]
  },
  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["AgenticHealthcareContainer"] }
  ]
}
