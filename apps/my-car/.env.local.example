PORT=3012

# Neon Postgres
DATABASE_URL=postgres://user:pass@ep-xxx.us-east-2.aws.neon.tech/my_car?sslmode=require

# Better Auth
BETTER_AUTH_SECRET=generate-with-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:3012
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3012
NEXT_PUBLIC_APP_URL=http://localhost:3012

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=my-car
# Optional — when unset, the app falls back to presigned GET URLs
R2_PUBLIC_DOMAIN=
