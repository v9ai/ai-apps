{
  "name": "bricks",
  "private": true,
  "scripts": {
    "dev": "concurrently \"pnpm run next-dev\" \"pnpm run backend-dev\" \"pnpm run deploy-dev\" \"pnpm run codegen-dev\"",
    "next-dev": "next dev --turbopack -p 3008",
    "backend-dev": "cd backend && uv run langgraph dev --no-browser --port 2025",
    "deploy-dev": "cd backend && uv run python deploy_server.py",
    "codegen-dev": "cd backend && bash start-codegen.sh",
    "build": "next build --webpack",
    "prepare": "panda codegen",
    "start": "next start",
    "prices:scrape": "node --env-file=.env.local --import tsx tools/scrape-set-prices.ts"
  },
  "dependencies": {
    "@ai-apps/auth": "workspace:*",
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@neondatabase/serverless": "^1.0.2",
    "@radix-ui/react-tabs": "^1.1.13",
    "@xyflow/react": "^12.10.1",
    "drizzle-orm": "^0.45.1",
    "lodash": "^4.17.23",
    "lucide-react": "^0.511.0",
    "next": "latest",
    "react": "^19",
    "react-dom": "^19"
  },
  "devDependencies": {
    "@pandacss/dev": "^1.9.0",
    "@types/lodash": "^4.17.24",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-bluetooth": "^0.0.21",
    "autoprefixer": "^10.4.19",
    "concurrently": "^9.2.1",
    "playwright": "^1.50.1",
    "postcss": "^8",
    "tsx": "^4.19.2",
    "typescript": "^5"
  }
}
