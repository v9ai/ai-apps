{
  "name": "bricks",
  "private": true,
  "scripts": {
    "dev": "concurrently \"pnpm run next-dev\" \"pnpm run backend-dev\"",
    "next-dev": "next dev --turbopack -p 3008",
    "backend-dev": "cd backend && uv run langgraph dev --no-browser --port 2025",
    "build": "next build --webpack",
    "prepare": "panda codegen",
    "start": "next start"
  },
  "dependencies": {
    "next": "latest",
    "react": "^19",
    "react-dom": "^19"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "postcss": "^8",
    "@pandacss/dev": "^1.9.0",
    "autoprefixer": "^10.4.19",
    "typescript": "^5"
  }
}
