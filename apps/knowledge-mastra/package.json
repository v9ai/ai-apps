{
  "name": "knowledge-mastra",
  "private": true,
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "mastra dev",
    "build": "mastra build",
    "deploy": "mastra deploy",
    "typecheck": "tsc --noEmit",
    "generate": "tsx --env-file=../knowledge/.env.local src/cli.ts",
    "generate:dry": "tsx --env-file=../knowledge/.env.local src/cli.ts --dry-run",
    "generate:missing": "tsx --env-file=../knowledge/.env.local src/cli.ts --list-missing",
    "generate:batch": "tsx --env-file=../knowledge/.env.local src/cli.ts --batch",
    "generate:graph": "tsx src/cli.ts --graph"
  },
  "dependencies": {
    "@mastra/core": "latest",
    "@mastra/deployer-cloudflare": "latest",
    "@mastra/pg": "latest",
    "@neondatabase/serverless": "^0.10.4",
    "drizzle-orm": "^0.45.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "mastra": "latest",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "wrangler": "latest",
    "@types/node": "^22"
  }
}
