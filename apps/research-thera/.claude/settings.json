{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "hooks": {
    "TeammateIdle": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'exec bash \"$(git rev-parse --show-toplevel)/apps/research-thera/.claude/hooks/teammate-idle.sh\"'",
            "timeout": 30
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'exec bash \"$(git rev-parse --show-toplevel)/apps/research-thera/.claude/hooks/task-completed.sh\"'",
            "timeout": 60
          }
        ]
      }
    ]
  }
}
