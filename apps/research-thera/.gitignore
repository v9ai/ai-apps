# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# wrangler
.wrangler/

# mastra (removed; kept to prevent re-committing stray build output)
.mastra/

# typescript
*.tsbuildinfo
next-env.d.ts
.env*.local

# cache directories
/cache
/.cache

# Cloned repositories
src/elevenlabs-examples/
.trigger/

# Python
.venv/
__pycache__/
*.pyc

# SQLite databases
*.db
*.db.backup

# Rust
**/target/
