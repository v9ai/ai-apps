{
  "name": "bs-detector-evals",
  "private": true,
  "scripts": {
    "eval": "promptfoo eval && promptfoo eval --config evals/promptfoo/fact-checking.yaml && promptfoo eval --config evals/promptfoo/citation-extraction.yaml",
    "eval:citations": "promptfoo eval",
    "eval:facts": "promptfoo eval --config evals/promptfoo/fact-checking.yaml",
    "eval:extract": "promptfoo eval --config evals/promptfoo/citation-extraction.yaml",
    "eval:precision": "promptfoo eval --config evals/promptfoo/prompt-precision-citations.yaml && promptfoo eval --config evals/promptfoo/prompt-precision-facts.yaml",
    "eval:reflection": "promptfoo eval --config evals/promptfoo/reflection-honesty.yaml",
    "eval:all": "pnpm run eval && pnpm run eval:precision && pnpm run eval:reflection",
    "eval:view": "promptfoo view"
  },
  "devDependencies": {
    "promptfoo": "^0.120.26"
  }
}
