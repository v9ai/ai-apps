{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "knowledge-langgraph",
  "main": "src/index.js",
  "compatibility_date": "2026-04-22",
  "observability": { "enabled": true },
  "vars": {
    "LLM_BASE_URL": "https://api.deepseek.com",
    "LLM_MODEL": "deepseek-chat"
  },
  "containers": [
    {
      "class_name": "KnowledgeContainer",
      "image": "./Dockerfile",
      "max_instances": 1,
      "instance_type": "standard-1"
    }
  ],
  "durable_objects": {
    "bindings": [
      { "name": "CONTAINER", "class_name": "KnowledgeContainer" }
    ]
  },
  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["KnowledgeContainer"] }
  ]
}
