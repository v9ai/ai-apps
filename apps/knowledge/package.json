{
  "name": "knowledge",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "next dev -p 3002",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "seed": "tsx --env-file=.env.local scripts/seed.ts",
    "seed:sqlite": "node --import tsx src/seed/seed-sqlite.ts",
    "seed:courses": "node --import tsx src/seed/seed-courses.ts",
    "migrate:neon-to-sqlite": "tsx --env-file=.env.local scripts/migrate-from-neon.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:generate": "drizzle-kit generate",
    "db:content:push": "drizzle-kit push --config=drizzle-content.config.ts",
    "db:content:studio": "drizzle-kit studio --config=drizzle-content.config.ts",
    "mastra:dev": "mastra dev",
    "mastra:build": "mastra build",
    "mastra:deploy": "mastra deploy",
    "generate": "tsx --env-file=.env.local scripts/generate-article.ts",
    "generate:dry": "tsx --env-file=.env.local scripts/generate-article.ts --dry-run",
    "generate:missing": "tsx --env-file=.env.local scripts/generate-article.ts --list-missing",
    "generate:batch": "tsx --env-file=.env.local scripts/generate-article.ts --batch",
    "generate:graph": "tsx scripts/generate-article.ts --graph",
    "review:courses": "tsx --env-file=.env.local scripts/review-courses.ts",
    "review:courses:dry": "tsx --env-file=.env.local scripts/review-courses.ts --dry-run",
    "scrape:udemy": "tsx --env-file=.env.local scripts/scrape-udemy-courses.ts"
  },
  "dependencies": {
    "@ai-apps/auth": "workspace:*",
    "@ai-apps/db-backup": "workspace:*",
    "@ai-apps/deepseek": "workspace:*",
    "@ai-apps/resume": "workspace:*",
    "@apollo/server": "^5.4.0",
    "@as-integrations/next": "^4.1.0",
    "@aws-sdk/client-s3": "^3.1029.0",
    "@graphql-tools/schema": "^10.0.31",
    "@mastra/core": "latest",
    "@mastra/deployer-cloudflare": "latest",
    "@mastra/pg": "latest",
    "@neondatabase/serverless": "^0.10.4",
    "@posthog/next": "^0.1.0",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/themes": "^3.3.0",
    "@react-pdf/renderer": "^4.3.2",
    "@xyflow/react": "^12.10.1",
    "better-sqlite3": "^12.6.2",
    "drizzle-orm": "^0.45.1",
    "graphql": "^16.13.2",
    "next": "latest",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "unist-util-visit": "^5.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/mdast": "^4.0.4",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.9",
    "mastra": "latest",
    "playwright": "^1.52.0",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "wrangler": "latest"
  }
}
