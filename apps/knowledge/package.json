{
  "name": "knowledge",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "next dev -p 3002",
    "build": "next build",
    "start": "next start",
    "seed": "tsx --env-file=.env.local scripts/seed.ts",
    "seed:sqlite": "node --import tsx src/seed/seed-sqlite.ts",
    "migrate:neon-to-sqlite": "tsx --env-file=.env.local scripts/migrate-from-neon.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:generate": "drizzle-kit generate",
    "db:content:push": "drizzle-kit push --config=drizzle-content.config.ts",
    "db:content:studio": "drizzle-kit studio --config=drizzle-content.config.ts",
    "generate": "cd ../knowledge-mastra && pnpm generate",
    "generate:dry": "cd ../knowledge-mastra && pnpm generate:dry",
    "generate:missing": "cd ../knowledge-mastra && pnpm generate:missing",
    "generate:batch": "cd ../knowledge-mastra && pnpm generate:batch",
    "generate:graph": "cd ../knowledge-mastra && pnpm generate:graph",
    "review:courses": "cd ../knowledge-mastra && pnpm review:courses",
    "review:courses:dry": "cd ../knowledge-mastra && pnpm review:courses:dry",
    "seed:courses": "node --import tsx src/seed/seed-courses.ts",
    "scrape:udemy": "tsx --env-file=.env.local scripts/scrape-udemy-courses.ts"
  },
  "dependencies": {
    "@ai-apps/auth": "workspace:*",
    "@ai-apps/db-backup": "workspace:*",
    "@ai-apps/resume": "workspace:*",
    "@apollo/server": "^5.4.0",
    "@as-integrations/next": "^4.1.0",
    "@aws-sdk/client-s3": "^3.1029.0",
    "@graphql-tools/schema": "^10.0.31",
    "@neondatabase/serverless": "^0.10.4",
    "@posthog/next": "^0.1.0",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/themes": "^3.3.0",
    "@react-pdf/renderer": "^4.3.2",
    "@xyflow/react": "^12.10.1",
    "better-sqlite3": "^12.6.2",
    "drizzle-orm": "^0.45.1",
    "graphql": "^16.13.2",
    "next": "latest",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/mdast": "^4.0.4",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.9",
    "playwright": "^1.52.0",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
