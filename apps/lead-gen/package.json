{
  "name": "agentic-lead-gen",
  "type": "module",
  "private": true,
  "scripts": {
    "stack": "cd crates/agentic-search && cargo run --release -- --root ../.. discover --output ../../src/app/stack/discovery.json",
    "dev": "concurrently -n next,ext,ws,posts -c blue,green,yellow,magenta \"next dev --webpack -p 3004\" \"pnpm --filter vite-web-extension dev\" \"tsx scripts/ext-reload-server.ts\" \"cargo run --manifest-path crates/linkedin-posts/Cargo.toml\"",
    "dev:next": "next dev --webpack -p 3004",
    "dev:ext": "concurrently -n next,ext,ws -c blue,green,yellow \"next dev --webpack -p 3004\" \"pnpm --filter vite-web-extension dev\" \"tsx scripts/ext-reload-server.ts\"",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "next lint",
    "demo:skills": "tsx scripts/demo-skills-in-production.ts",
    "try:skills": "tsx scripts/try-skills-production.ts",
    "deploy": "tsx scripts/deploy.ts",
    "codegen": "graphql-codegen",
    "ccx:scrape": "tsx scripts/scrape-from-ccx.ts",
    "linkedin:people": "tsx scripts/scrape-linkedin-people.ts",
    "clean:contacts": "tsx scripts/clean-contacts.ts",
    "strategy:check": "tsx scripts/enforce-strategy.ts",
    "strategy:check:all": "tsx scripts/enforce-strategy.ts --all",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "panda": "panda",
    "panda:codegen": "panda codegen",
    "prepare": "panda codegen"
  },
