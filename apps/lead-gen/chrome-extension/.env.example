# Chrome Extension Environment Variables
# Copy this file to .env.local and fill in your values

# API Secret for job insertion (optional)
VITE_API_SECRET=

# Next.js app base URL (defaults to http://localhost:3000)
# VITE_API_BASE_URL=http://localhost:3000

# GraphQL API URL (defaults to http://localhost:3004/api/graphql to match dev server port)
# VITE_GRAPHQL_URL=http://localhost:3004/api/graphql

# LinkedIn posts API base URL. Defaults to http://localhost:9876 (legacy
# Rust server, or the FastAPI port of it run locally). For production set
# to the CF dispatcher's /linkedin prefix:
# VITE_LINKEDIN_API_URL=https://lead-gen-langgraph.eeeew.workers.dev/linkedin
# Back-compat: VITE_RUST_SERVER_URL is read as a fallback if unset.
