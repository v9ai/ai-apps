# Chrome Extension Environment Variables
# Copy this file to .env.local and fill in your values

# API Secret for job insertion (optional)
VITE_API_SECRET=

# Next.js app base URL (defaults to http://localhost:3000)
# VITE_API_BASE_URL=http://localhost:3000

# GraphQL API URL for block company feature (defaults to http://localhost:3000/api/graphql)
# VITE_GRAPHQL_URL=http://localhost:3000/api/graphql
