# Chrome Extension Environment Variables
# Copy this file to .env.local and fill in your values

# API Secret for job insertion (optional)
VITE_API_SECRET=

# Next.js app base URL (defaults to http://localhost:3000)
# VITE_API_BASE_URL=http://localhost:3000

# GraphQL API URL (defaults to http://localhost:3004/api/graphql to match dev server port)
# VITE_GRAPHQL_URL=http://localhost:3004/api/graphql

# LinkedIn posts API base URL. Defaults to http://localhost:8002/linkedin
# (the FastAPI router mounted in the core LangGraph backend, started by
# `pnpm backend-dev`). For production set to the CF dispatcher's /linkedin
# prefix:
# VITE_LINKEDIN_API_URL=https://lead-gen-langgraph.eeeew.workers.dev/linkedin
# Back-compat: VITE_RUST_SERVER_URL is read as a fallback if unset.

# D1 import endpoint for the "Import all opportunities" button on
# linkedin.com/jobs/search. Routes to the edge worker at
# apps/lead-gen/edge/src/index.ts → /api/jobs/d1/import.
# Local dev: `wrangler dev` in apps/lead-gen/edge serves on :8787.
VITE_JOBS_D1_API_URL=http://localhost:8787

# Bearer token gating /api/jobs/d1/import. Must match the value of
# `wrangler secret put JOBS_D1_TOKEN` on the edge worker.
VITE_JOBS_D1_TOKEN=

# LangGraph backend (used for the score_recruiter_fit graph triggered after
# Browse Recruiters saves a profile). Local dev: `pnpm backend-dev` exposes
# http://127.0.0.1:8002. For HF / CF deploys set the public URL + bearer.
VITE_LANGGRAPH_URL=http://127.0.0.1:8002
VITE_LANGGRAPH_AUTH_TOKEN=
