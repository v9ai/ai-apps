{
  "manifest_version": 3,
  "name": "Agentic Lead Gen Assistant",
  "description": "Agentic AI-powered assistant for B2B lead generation, company enrichment, and outreach automation",
  "version": "1.0.0",
  "options_ui": {
    "page": "src/pages/options/index.html"
  },
  "action": {
    "default_popup": "src/pages/popup/index.html",
    "default_icon": {
      "32": "icon-32.png"
    }
  },
  "icons": {
    "128": "icon-128.png"
  },
  "background": {
    "service_worker": "src/pages/background/index.ts",
    "type": "module"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs",
    "cookies"
  ],
  "host_permissions": [
    "http://localhost:3000/*",
    "http://localhost:3004/*",
    "http://localhost:9876/*",
    "https://*.linkedin.com/*",
    "https://*.google.com/*",
    "https://*.ashbyhq.com/*",
    "https://*.greenhouse.io/*",
    "https://*.lever.co/*",
    "https://*.workable.com/*",
    "https://www.founderio.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://*.linkedin.com/jobs/*",
        "https://*.linkedin.com/feed/*",
        "https://*.linkedin.com/search/*",
        "https://*.google.com/search*",
        "https://*.ashbyhq.com/*",
        "https://*.greenhouse.io/*",
        "https://*.lever.co/*",
        "https://www.founderio.com/jobs*",
        "https://www.founderio.com/job/*",
        "https://*.workable.com/*"
      ],
      "js": ["src/pages/content/index.tsx"],
      "run_at": "document_idle"
    }
  ],
  "devtools_page": "src/pages/devtools/index.html",
  "web_accessible_resources": [
    {
      "resources": ["contentStyle.css", "icon-128.png", "icon-32.png"],
      "matches": ["<all_urls>"]
    }
  ]
}
