# Better Auth (@ai-apps/auth)
BETTER_AUTH_SECRET=your-secret-here
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# Base URL of your application
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database Configuration (Neon PostgreSQL)
NEON_DATABASE_URL=

# ============================================
# LLM Provider Configuration
# ============================================
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
# DeepSeek model defaults (v4 family — `deepseek-chat` / `deepseek-reasoner`
# deprecate on 2026-07-24). Source of truth: src/lib/deepseek/constants.ts
# (TS) and backend/leadgen_agent/llm.py DEEPSEEK_MODELS (Python). Override
# per-environment only if you need a non-default tier.
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_MODEL_DEEP=deepseek-v4-pro

# ============================================
# LangGraph backend (apps/lead-gen/backend)
# ============================================
# URL of the LangGraph dev server — start with `pnpm backend-dev`.
# For Vercel-hosted Next.js reaching a local backend, set this to the
# public tunnel URL (see backend/README.md).
LANGGRAPH_URL=http://127.0.0.1:8002
# Optional shared secret. When set, the backend requires
# `Authorization: Bearer <token>` on every request (except /ok, /info).
# Required whenever LANGGRAPH_URL is a public tunnel; leave blank locally.
# Must match the value exported to backend/.env and Vercel env.
LANGGRAPH_AUTH_TOKEN=
# Which product-intel graph the frontend invokes. Set to "v2" after verifying
# fan-out and cache-load parity (default: v1).
PRODUCT_INTEL_GRAPH_VERSION=v1
# Gate for scripts/import-paper-authors.ts. The 2026-04-22 import created
# 1,404 dead-end contacts; the script now refuses to run unless this is set
# to "1" (or --force is passed). Leave unset in shared envs.
LEADGEN_ALLOW_PAPER_IMPORT=
# LLM target used by graphs and the opportunity classifier.
# Local dev: point at mlx_lm.server (defaults below).
# Production (Vercel): point LLM_BASE_URL at the lead-gen-opportunity-llm Worker
# (`https://lead-gen-opportunity-llm.<subdomain>.workers.dev/v1`) and set
# LLM_API_KEY to the value of OPPORTUNITY_LLM_SHARED_SECRET on that Worker.
LLM_BASE_URL=http://localhost:8080/v1
LLM_API_KEY=local
LLM_MODEL=default_model
# Override only the opportunity classifier (src/ml/opportunity-classifier.ts).
# CF Worker setup: `mistral-opportunity-lora`. Local mlx_lm.server: leave unset.
LLM_MODEL_OPPORTUNITY=
# Backend-only — required when running app.py (HF Spaces) for AsyncPostgresSaver.
# Use the Neon *pooled* connection string (hostname contains `-pooler`) with
# sslmode=require. Not read by the Next.js frontend; set this only in
# backend/.env or the HF Space secrets, not in Vercel.
DATABASE_URL=

# ============================================
# Pipeline Configuration
# ============================================
# Target ICP vertical for lead scoring priority
# Valid values: consultancy, agency, staffing, product
ICP_VERTICAL=consultancy

# API Keys for bulk operations
ADMIN_EMAIL=admin@example.com

# Inngest Configuration
INNGEST_EVENT_KEY=

# Resend (email)
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=re_...
# Get webhook secret from https://resend.com/webhooks
RESEND_WEBHOOK_SECRET=whsec_...

# NeverBounce (email verification for contact email discovery)
# Get your API key from https://app.neverbounce.com/settings/api
NEVERBOUNCE_API_KEY=your-neverbounce-api-key

# Brave Search (discovery pipeline — LangChain BraveSearchWrapper)
# Get your API key from https://brave.com/search/api/
BRAVE_SEARCH_API_KEY=

# HuggingFace Inference API (JobBERT-v3 embeddings)
# Get token at https://huggingface.co/settings/tokens (needs "Inference Providers" permission)
HF_TOKEN=hf_...

FIGMA_ACCESS_TOKEN=
