// Cloudflare Worker fronting Workers AI + Mistral LoRA for lead-gen email generation.
//
// DEPLOY:
//   pnpm install
//   wrangler secret put EMAIL_LLM_SHARED_SECRET     # random 32+ char token
//   pnpm deploy
//   # optional, after LoRA upload:
//   wrangler secret put FINETUNE_ID                 # UUID from `wrangler ai finetune list`
//
// UPLOAD LORA (after training produces ../mlx-training/peft/out/adapter/final/cf-upload/):
//   npx wrangler ai finetune create \
//     @cf/mistral/mistral-7b-instruct-v0.2-lora \
//     email-lora-v1 \
//     ../../mlx-training/peft/out/adapter/final/cf-upload
//
// BACKEND SWAP (flip backend/wrangler.jsonc to use this Worker as its LLM):
//   vars.LLM_BASE_URL -> "https://lead-gen-email-llm.<SUBDOMAIN>.workers.dev/v1"
//   vars.LLM_MODEL    -> "mistral-email-lora"
//   secret LLM_API_KEY = same value as EMAIL_LLM_SHARED_SECRET on this Worker
//   Do not flip until this Worker is deployed or every backend LLM call will 401/404.
{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "lead-gen-email-llm",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-01",
  "observability": { "enabled": true },
  "ai": { "binding": "AI" },
  "vars": {
    "MODEL_NAME": "@cf/mistral/mistral-7b-instruct-v0.2-lora",
    "MODEL_ALIAS": "mistral-email-lora"
  }
}
