// Top-level dispatcher Worker for the 3-container lead-gen split.
//
// Deploys three Workers total (per-sub-container configs):
//   - backend/core/wrangler.jsonc      → lead-gen-core
//   - backend/ml/wrangler.jsonc        → lead-gen-ml
//   - backend/research/wrangler.jsonc  → lead-gen-research
//
// This top-level Worker sits in front of all three and exposes the single
// public hostname `lead-gen-langgraph.eeeew.workers.dev`. All external
// traffic enters here; service bindings forward to the right sub-Worker.
//
// Deploy order matters (service bindings must resolve): run
// `bash scripts/deploy-cf.sh all` which sequences ml → research → core →
// dispatcher.
{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "lead-gen-langgraph",
  "main": "src/dispatcher.js",
  "compatibility_date": "2026-04-01",
  "compatibility_flags": ["nodejs_compat"],
  "observability": { "enabled": true },
  "services": [
    { "binding": "CORE",     "service": "lead-gen-core" },
    { "binding": "ML",       "service": "lead-gen-ml" },
    { "binding": "RESEARCH", "service": "lead-gen-research" }
  ],
  "vars": {
    // SHA-256 hex of the shared LANGGRAPH_AUTH_TOKEN. Populate via
    //   echo -n "<token>" | shasum -a 256
    // and `wrangler deploy` (the digest is non-secret — just a hash).
    // The raw token lives in sub-Worker secrets only.
    "LANGGRAPH_AUTH_TOKEN_HASH": ""
  }
}
