{
  "$schema": "../node_modules/wrangler/config-schema.json",
  "name": "lead-gen-core",
  "main": "src/index.js",
  "compatibility_date": "2026-04-01",
  "observability": { "enabled": true },
  "vars": {
    "LLM_BASE_URL": "https://api.deepseek.com",
    // Source of truth: src/lib/deepseek/constants.ts (DEEPSEEK_MODELS.pro.id),
    // mirrored in backend/_shared/deepseek-constants.js. wrangler.jsonc cannot
    // import code, so the literal is duplicated here — keep in sync.
    "LLM_MODEL": "deepseek-v4-pro",
    "EMAIL_LLM_BASE_URL": "https://lead-gen-email-llm.eeeew.workers.dev/v1",
    "EMAIL_LLM_MODEL": "mistral-email-lora",
    // Service-binding hostnames — the dispatcher Worker routes these; Core's
    // RemoteGraph adapters fetch to lead-gen-ml / lead-gen-research via CF's
    // internal service DNS. Override at deploy-time if needed.
    "ML_URL": "http://lead-gen-ml",
    "RESEARCH_URL": "http://lead-gen-research"
  },
  "containers": [
    {
      "class_name": "CoreContainer",
      "image": "./Dockerfile",
      "max_instances": 1,
      "instance_type": "standard-1"
    }
  ],
  "durable_objects": {
    "bindings": [
      { "name": "CONTAINER", "class_name": "CoreContainer" }
    ]
  },
  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["CoreContainer"] }
  ],
  // Cron triggers fire `scheduled()` in src/index.js, which POSTs to the
  // container's /cron/tick endpoint (Python). Off-minute slots (:17, :47)
  // avoid the cron-storm that hits CF on round minutes. UTC.
  "triggers": {
    "crons": [
      "17 6 * * *",   // daily 06:17 UTC — Ashby discover + ingest
      "47 6 * * 1",   // Mondays 06:47 UTC — full re-ingest of known boards
      "23 */6 * * *", // every 6 hours :23 — country-classify mop-up
      "37 */4 * * *"  // every 4 hours :37 — remote-classify D1 opportunities
    ]
  }
}
