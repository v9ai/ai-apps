  <!-- Galaxy core glow layers -->
  <circle cx="150" cy="96" r="38" fill="url(#coreGlow)" filter="url(#coreBlur)" clip-path="url(#vbClip)"/>
  <circle cx="150" cy="96" r="22" fill="#9333ea" opacity="0.5" filter="url(#armBlur)" clip-path="url(#vbClip)"/>
  <circle cx="150" cy="96" r="12" fill="#c084fc" opacity="0.75" filter="url(#dustGlow)" clip-path="url(#vbClip)"/>
