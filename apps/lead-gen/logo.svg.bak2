  <circle cx="150" cy="96" r="2.5" fill="#ffffff" opacity="1" clip-path="url(#vbClip)"/>

  <!-- ALG at core -->
  <text x="150" y="100"
    font-family="'Arial Black','Arial Bold',Arial,sans-serif"
    font-weight="900" font-size="13" letter-spacing="1.5"
    text-anchor="middle" fill="#ffffff"
    filter="url(#textGlow)" clip-path="url(#vbClip)">ALG</text>

  <!-- Bottom label -->
  <text x="150" y="192"
    font-family="Arial,sans-serif"
    font-weight="400" font-size="8.5" letter-spacing="3.5"
    text-anchor="middle" fill="#a78bfa" opacity="0.75">AGENTIC LEAD GEN</text>
