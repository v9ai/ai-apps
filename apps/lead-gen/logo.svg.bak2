  </g>

  <!-- Outer haze disk -->
  <ellipse cx="150" cy="96" rx="110" ry="58" fill="url(#hazeGrad)" clip-path="url(#vbClip)"/>

  <!-- Spiral arms — blurred base -->
  <g filter="url(#armBlur)" clip-path="url(#vbClip)">
    <path d="M150,96 C158,86 172,78 188,74 C205,70 222,72 236,80 C248,87 255,98 252,110 C249,120 238,126 224,124 C210,122 198,112 192,100"
