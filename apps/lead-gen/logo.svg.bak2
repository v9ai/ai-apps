    <circle cx="260" cy="42" r="0.5" fill="#ddd6fe"/><circle cx="283" cy="35" r="0.3" fill="#c4b5fd"/>
    <circle cx="15" cy="65" r="0.4" fill="#e9d5ff"/><circle cx="40" cy="72" r="0.3" fill="#d8b4fe"/>
    <circle cx="65" cy="58" r="0.5" fill="#ddd6fe"/><circle cx="88" cy="70" r="0.3" fill="#c4b5fd"/>
