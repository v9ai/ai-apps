    <path d="M150,96 C158,108 166,122 168,138 C170,154 164,168 154,174 C144,180 132,174 126,164 C120,154 124,140 134,130 C144,120 152,116 150,96"
      fill="none" stroke="#8b5cf6" stroke-width="12" stroke-linecap="round" opacity="0.3"/>
  </g>

  <!-- Spiral arms — bright edges -->
  <g clip-path="url(#vbClip)">
    <path d="M150,96 C158,86 172,78 188,74 C205,70 222,72 236,80 C248,87 255,98 252,110 C249,120 238,126 224,124 C210,122 198,112 192,100"
      fill="none" stroke="#c084fc" stroke-width="2.5" stroke-linecap="round" opacity="0.7"/>
    <path d="M150,96 C142,84 134,70 130,54 C126,38 130,22 140,14 C150,6 164,10 172,20 C180,30 178,46 168,58 C158,68 148,72 150,96"
      fill="none" stroke="#c084fc" stroke-width="2" stroke-linecap="round" opacity="0.65"/>
    <path d="M150,96 C142,106 128,114 112,118 C96,122 80,118 68,110 C56,102 50,90 54,78 C58,67 70,61 84,64 C98,67 110,78 116,92"
      fill="none" stroke="#c084fc" stroke-width="2.5" stroke-linecap="round" opacity="0.7"/>
    <path d="M150,96 C158,108 166,122 168,138 C170,154 164,168 154,174 C144,180 132,174 126,164 C120,154 124,140 134,130 C144,120 152,116 150,96"
      fill="none" stroke="#c084fc" stroke-width="2" stroke-linecap="round" opacity="0.65"/>
  </g>

  <!-- Inner spiral wisps -->
  <g filter="url(#dustGlow)" clip-path="url(#vbClip)" opacity="0.6">
    <path d="M150,96 C155,90 164,86 174,86 C184,86 192,92 194,100 C196,108 190,114 182,112 C174,110 168,102 168,96"
      fill="none" stroke="#d8b4fe" stroke-width="1.5" stroke-linecap="round"/>
    <path d="M150,96 C145,102 136,106 126,106 C116,106 108,100 108,92 C108,84 116,80 124,82 C132,84 138,92 138,96"
      fill="none" stroke="#d8b4fe" stroke-width="1.5" stroke-linecap="round"/>
    <path d="M150,96 C153,92 158,89 164,89 C170,89 176,93 178,99 C180,105 176,110 170,109"
      fill="none" stroke="#e9d5ff" stroke-width="1" stroke-linecap="round" opacity="0.8"/>
    <path d="M150,96 C147,100 142,103 136,103 C130,103 124,99 124,93 C124,87 130,84 136,85"
      fill="none" stroke="#e9d5ff" stroke-width="1" stroke-linecap="round" opacity="0.8"/>
  </g>

