{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "pnpm run build",
  "devCommand": "pnpm run dev",
  "installCommand": "cd ../.. && pnpm install --no-frozen-lockfile",
  "framework": "nextjs",
  "ignoreCommand": "npx turbo-ignore",
  "functions": {
    "src/app/api/**/*.ts": {
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/api/cron/backup",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/cpn-campaign",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/followup-scheduler",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/intel-runs-sweeper",
      "schedule": "*/5 * * * *"
    }
  ]
}
