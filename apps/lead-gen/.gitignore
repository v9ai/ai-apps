# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# wrangler local secrets (root .gitignore covers .env* but not .dev.vars)
**/.dev.vars
**/.dev.vars.*

# env files (can opt-in for commiting if needed)
.env
.env.local
.env.local.*
.env.local.backup
.env.development

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# mastra
.mastra/
.env.vercel.local

.env*.local
*.pyc
__pycache__/
.venv/
.venv-*/
.venv-workers/

# LangGraph dev server runtime state
backend/.langgraph_api/

# better-auth configuration (can include secrets)

# script logs
scripts/*.log

# workspace runtime files
workspace/*
!workspace/.gitkeep
src/workspace/skills/*
!src/workspace/skills/*.md
results/*.json

# MCP / Playwright MCP
.mcp.json
.playwright-mcp/

# Claude Code local settings (may contain secrets)
.claude/settings.local.json

# Generated docs (build-lh-docs.ts)
public/docs/

# Rust build artifacts
**/target/

# MLX fine-tuning (adapters + exported training data)
mlx-training/models/
mlx-training/data/

# LlamaIndex local storage
llamaindex/.storage/

# SQLite databases
data/*.db
data/*.db-wal
data/*.db-shm

# PandaCSS generated output
/styled-system/