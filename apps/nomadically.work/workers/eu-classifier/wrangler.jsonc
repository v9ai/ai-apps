{
  "name": "nomadically-work-eu-classifier",
  "main": "src/entry.py",
  "compatibility_date": "2025-11-02",
  "compatibility_flags": ["python_workers"],
  // Cron trigger — runs every 6 hours (classifies role-match jobs)
  "triggers": {
    "crons": ["0 */6 * * *"]
  },
  "ai": {
    "binding": "AI",
    "remote": true,
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "nomadically-work-db",
      "database_id": "632b9c57-8262-40bd-86c2-bc08beab713b",
      "remote": true,
    },
  ],
  // queues: disabled — eu-classifier-queue/dlq not yet created (wrangler queues create fails on current plan).
  // The cron + HTTP /classify endpoint are the primary triggers; queue consumer is optional.
  // Re-enable once queues are created via CF dashboard.
  "vars": {
    "LANGCHAIN_TRACING_V2": "true",
    "LANGCHAIN_PROJECT": "nomadically-work-eu-classifier",
  },
  "observability": {
    "enabled": true,
    "logs": {
      "enabled": true,
      "invocation_logs": true,
      "head_sampling_rate": 1.0,
    },
  },
}
