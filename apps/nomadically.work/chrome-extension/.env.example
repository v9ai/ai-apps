# Chrome Extension Environment Variables
# Copy this file to .env.local and fill in your values

# Cloudflare Worker API Secret (optional)
# Get this from your worker's environment variables
# To set on worker: npx wrangler secret put API_SECRET --name nomadically-work-insert-jobs
VITE_API_SECRET=

# Worker URL (optional override)
# VITE_WORKER_URL=https://nomadically-work-insert-jobs.eeeew.workers.dev
