{
  "statusLine": {
    "type": "command",
    "command": "bash -c 'exec bash \"$(git rev-parse --show-toplevel)/.claude/iterate/statusline.sh\"'"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'exec bash \"$(git rev-parse --show-toplevel)/.claude/hooks/session-start.sh\"'",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'exec bash \"$(git rev-parse --show-toplevel)/.claude/iterate/kick-session.sh\"'",
            "timeout": 300
          },
          {
            "type": "command",
            "command": "bash -c 'exec bash \"$(git rev-parse --show-toplevel)/.claude/hooks/stop-save.sh\"'",
            "timeout": 60
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'exec bash \"$(git rev-parse --show-toplevel)/.claude/hooks/pre-compact-save.sh\"'",
            "timeout": 120
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c '(python3 -c \"import sys; sys.path.insert(0,\\\"'\"$(git rev-parse --show-toplevel 2>/dev/null || echo .)\"'/.claude/hooks\\\"); import iteration_memory as mem; mem.store(\\\"Session ended\\\", \\\"progress\\\", \\\"${CLAUDE_WORKTREE:-default}\\\", ${CLAUDE_ITERATION:-0})\" &) 2>/dev/null'",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
