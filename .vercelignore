# Exclude all apps except agentic-healthcare, lead-gen, todo, knowledge, bricks, and research-thera
apps/podcasts
apps/real-estate
apps/vadim.blog

# Exclude packages not needed
packages/qwen
packages/llm-router
packages/og
packages/logger

# Exclude Rust/Python/other build artifacts
crates
langgraph
/scripts
target

# Large binary files
*.gguf
*.wav
*.dylib
*.so
*.wal

# Python virtualenvs
.venv
.venv-workers

# App-specific large dirs
apps/lead-gen/consultancies
apps/lead-gen/leadgen-metal
apps/lead-gen/mlx-training
apps/bricks/public/clips
apps/bricks/*.gguf

# Common exclusions (use specific paths, not 'dist' to preserve packages/ui/dist)
node_modules
.turbo
*.log
# All apps' Next build/cache output — Vercel rebuilds from source
apps/*/.next
# Python tooling caches in any app
apps/*/.mypy_cache
apps/*/.ruff_cache
apps/*/.pytest_cache
apps/knowledge/evals
apps/knowledge/backend
apps/bricks/backend
apps/research-thera/backend
apps/research-thera/research-output
apps/research-thera/evals
apps/research-thera/better-auth
apps/research-thera/.agents

# Claude Code worktrees (dangling symlinks break vercel tar)
.claude/worktrees
.claude
apps/research-thera/.claude
__pycache__
*.egg-info
.langgraph_api
.wrangler

# --- auto-appended by scripts/deploy-vercel.ts for target=research-thera ---
# Other apps not depended on by the deploy target
apps/bricks
apps/hoa
apps/knowledge
apps/law-adversarial
apps/lead-gen
apps/movies
apps/nomadically.work
apps/real-estate
apps/travel
apps/vadim.blog
# Workspace packages not depended on by the deploy target
packages/auth
packages/company-intel
packages/config-eslint
packages/config-typescript
packages/db-backup
packages/deepseek
packages/jest-presets
packages/llm-router
packages/logger
packages/og
packages/qwen
packages/research
packages/resume
packages/ui
