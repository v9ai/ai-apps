# Exclude all apps except agentic-healthcare, lead-gen, todo, and knowledge
apps/podcasts
apps/real-estate
apps/research-thera
apps/vadim.blog
apps/bricks

# Exclude packages not needed
packages/qwen
packages/llm-router
packages/og
packages/logger

# Exclude Rust/Python/other build artifacts
crates
langgraph
scripts
target

# Large binary files
*.gguf
*.wav
*.dylib
*.so
*.wal

# Python virtualenvs
.venv
.venv-workers

# App-specific large dirs
apps/lead-gen/consultancies
apps/lead-gen/leadgen-metal

# Common exclusions (use specific paths, not 'dist' to preserve packages/ui/dist)
node_modules
.turbo
*.log
apps/agentic-healthcare/.next
__pycache__
*.egg-info
.langgraph_api
.wrangler
