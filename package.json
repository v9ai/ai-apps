{
  "name": "kitchen-sink",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "clean": "turbo run clean",
    "dev": "turbo run dev",
    "dev:h": "turbo run dev --filter=agentic-healthcare",
    "dev:l": "turbo run dev --filter=law-adversarial",
    "dev:n": "turbo run dev --filter=nomadically.work",
    "dev:r": "turbo run dev --filter=research-thera",
    "dev:b": "turbo run dev --filter=vadim.blog",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "check-types": "turbo run check-types",
    "deploy:blog": "vercel deploy --prod --archive=tgz --cwd apps/vadim.blog",
    "deploy:l": "vercel deploy --prod --archive=tgz --cwd apps/law-adversarial",
    "deploy:n": "vercel deploy --prod --archive=tgz --cwd apps/nomadically.work",
    "deploy:h": "vercel deploy --prod --archive=tgz --cwd apps/agentic-healthcare",
    "deploy:r": "vercel deploy --prod --archive=tgz --cwd apps/research-thera",
    "deploy:all": "pnpm deploy:n && pnpm deploy:l && pnpm deploy:h && pnpm deploy:r && pnpm deploy:blog"
  },
  "devDependencies": {
    "napi-postinstall": "^0.2.4",
    "prettier": "^3.6.0",
    "turbo": "^2.8.12"
  },
  "packageManager": "pnpm@8.15.6",
  "engines": {
    "node": ">=18"
  }
}
