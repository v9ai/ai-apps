{
  "name": "kitchen-sink",
  "private": true,
  "scripts": {
    "build": "turbo run build",

    "dev": "turbo run dev",
    "dev:h": "turbo run dev --filter=agentic-healthcare",
    "dev:l": "turbo run dev --filter=law-adversarial",
    "dev:n": "turbo run dev --filter=nomadically.work",
    "dev:r": "turbo run dev --filter=research-thera",
    "dev:b": "turbo run dev --filter=vadim.blog",
    "dev:re": "turbo run dev --filter=real-estate",
    "dev:k": "turbo run dev --filter=knowledge",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "lint": "turbo run lint",
    "test": "turbo run test",

    "deploy:blog": "vercel deploy --prod --archive=tgz --cwd apps/vadim.blog",
    "deploy:l": "vercel deploy --prod --archive=tgz --cwd apps/law-adversarial",
    "deploy:n": "vercel deploy --prod --archive=tgz --cwd apps/nomadically.work",
    "deploy:h": "vercel deploy --prod --archive=tgz --cwd apps/agentic-healthcare",
    "deploy:r": "vercel deploy --prod --archive=tgz --cwd apps/research-thera",
    "deploy:re": "vercel deploy --prod --archive=tgz --cwd apps/real-estate",
    "deploy:all": "pnpm deploy:n && pnpm deploy:l && pnpm deploy:h && pnpm deploy:r && pnpm deploy:re && pnpm deploy:blog"
  },
  "devDependencies": {
    "napi-postinstall": "^0.2.4",
    "prettier": "^3.6.0",
    "turbo": "^2.8.12"
  },
  "packageManager": "pnpm@10.31.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@apollo/protobufjs",
      "@clerk/shared",
"@swc/core",
      "better-sqlite3",
      "core-js",
      "core-js-pure",
      "esbuild",
      "onnxruntime-node",
      "protobufjs",
      "sharp",
      "tree-sitter",
      "unrs-resolver",
      "workerd"
    ]
  }
}
