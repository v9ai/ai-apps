{
  "name": "kitchen-sink",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:h": "turbo run dev --filter=agentic-healthcare & cd apps/agentic-healthcare/langgraph && uv run uvicorn chat_server:app --port 8001 --reload",
    "dev:l": "turbo run dev --filter=law-adversarial",
    "dev:n": "turbo run dev --filter=lead-gen",
    "dev:r": "turbo run dev --filter=research-thera",
    "dev:b": "turbo run dev --filter=vadim.blog",
    "dev:re": "turbo run dev --filter=real-estate & cd apps/real-estate/analyzer && uv run uvicorn server:app --port 8005 --reload",
    "dev:k": "turbo run dev --filter=knowledge",
    "dev:t": "turbo run dev --filter=todo",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "deploy:blog": "vercel deploy --prod --cwd apps/vadim.blog",
    "deploy:l": "VERCEL_PROJECT_ID=prj_LOKs6EndDbg0ZfkP8Nm2n86j0nok VERCEL_ORG_ID=team_PWwGsn3xORVtRDLLoES2BYVV vercel deploy --prod",
    "deploy:n": "VERCEL_PROJECT_ID=prj_YK5twFzCLh0okpfWRptY0AXwJZEL VERCEL_ORG_ID=team_PWwGsn3xORVtRDLLoES2BYVV vercel deploy --prod",
    "deploy:h": "vercel deploy --prod",
    "deploy:r": "vercel deploy --prod --cwd apps/research-thera",
    "deploy:re": "vercel deploy --prod --cwd apps/real-estate",
    "deploy:k": "VERCEL_PROJECT_ID=prj_HmZ37BPDql0kOnFT9iiPsnQBOryr VERCEL_ORG_ID=team_PWwGsn3xORVtRDLLoES2BYVV vercel deploy --prod",
    "deploy:t": "vercel deploy --prod --cwd apps/todo",
    "deploy:p": "vercel deploy --prod --cwd apps/podcasts",
    "dev:p": "turbo run dev --filter=humans-of-ai",
    "dev:br": "turbo run dev --filter=bricks",
    "dev:tr": "turbo run dev --filter=travel",
    "dev:z": "turbo run dev --filter=zoe",
    "deploy:z": "VERCEL_PROJECT_ID=prj_ztwL2Z83O6QI7PZ9QvjdnWODUtmV VERCEL_ORG_ID=team_PWwGsn3xORVtRDLLoES2BYVV vercel deploy --prod",
    "deploy:all": "pnpm deploy:n && pnpm deploy:l && pnpm deploy:h && pnpm deploy:r && pnpm deploy:re && pnpm deploy:blog && pnpm deploy:p"
  },
  "devDependencies": {
    "napi-postinstall": "^0.2.4",
    "prettier": "^3.6.0",
    "tsx": "^4.21.0",
    "turbo": "^2.8.12",
    "vercel": "^50.32.5"
  },
  "packageManager": "pnpm@10.31.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@apollo/protobufjs",
      "@swc/core",
      "better-sqlite3",
      "core-js",
      "core-js-pure",
      "esbuild",
      "onnxruntime-node",
      "protobufjs",
      "sharp",
      "tree-sitter",
      "unrs-resolver",
      "workerd"
    ]
  }
}
